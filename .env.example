# NextAuth
NEXTAUTH_SECRET=your_super_secret_key_here_min_32_chars
NEXTAUTH_URL=http://localhost:5000

# Admin Credentials
ADMIN_EMAIL=admin@portfolio.dev
ADMIN_PASSWORD=your_secure_password_here

# Database
DATABASE_URL=file:./dev.db
# For production, set DATABASE_URL in Vercel environment variables.
# Example for PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/portfolio

# SEO (Google Search Console — meta tag verification)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_string_from_google

